[
  {
    "name": "AgentTaskDispatcher",
    "scriptFile": "AIAgents.Functions.dll",
    "entryPoint": "AIAgents.Functions.Functions.AgentTaskDispatcher.Run",
    "language": "dotnet-isolated",
    "properties": {
      "IsCodeless": false
    },
    "bindings": [
      {
        "name": "messageText",
        "direction": "In",
        "type": "queueTrigger",
        "dataType": "String",
        "queueName": "agent-tasks",
        "connection": "AzureWebJobsStorage",
        "properties": {}
      }
    ]
  },
